{{define "form"}}
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{.PageTitle}} - {{.SiteTitle}}</title>
  <link rel="stylesheet" href="{{.BasePath}}/static/admin.css">
  <script src="{{.BasePath}}/static/admin.js" defer></script>
</head>
<body class="app-{{.App.Name}} model-{{.Resource.Name}} change-form">
  <div id="container">
    <div id="header">
      <div id="branding">
        <h1 id="site-name"><a href="{{.BasePath}}/">{{.SiteTitle}}</a></h1>
      </div>
    </div>
    <div class="breadcrumbs">
      <a href="{{.BasePath}}/">Home</a> &rsaquo;
      <a href="{{.BasePath}}/{{.App.Name}}/">{{.App.Label}}</a> &rsaquo;
      <a href="{{.BackURL}}">{{.Resource.Label}}</a> &rsaquo;
      {{.PageTitle}}
    </div>
    <div id="content" class="colM">
      <h1>{{.PageTitle}}</h1>
      {{if .DeleteURL}}
        <ul class="object-tools">
          <li><a class="deletelink" href="{{.DeleteURL}}">Delete</a></li>
        </ul>
      {{end}}
      <div id="content-main">
        <form method="post" action="{{.ActionURL}}" id="{{.Resource.Name}}_form">
          <input type="hidden" name="go_admin_csrf" value="{{.CSRFToken}}">
          {{range .Fieldsets}}
            <fieldset class="module aligned{{if .Collapsed}} collapse{{end}}">
              {{if .Title}}<h2>{{.Title}}</h2>{{end}}
              {{if .Description}}<div class="description">{{.Description}}</div>{{end}}
              {{range .Fields}}
                {{if .Readonly}}
                  <div class="form-row field-{{.Field.NameValue}}">
                    <div>
                      <label>{{.Field.LabelValue}}:</label>
                      <div class="readonly">{{.Display}}</div>
                    </div>
                  </div>
                {{else}}
                  {{safe .Widget}}
                {{end}}
              {{end}}
            </fieldset>
          {{end}}
          <div class="submit-row">
            <input type="submit" value="Save" class="default">
            <a href="{{.BackURL}}" class="closelink">Cancel</a>
          </div>
        </form>
      </div>
    </div>
  </div>
</body>
</html>
{{end}}
