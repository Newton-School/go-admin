{{define "list"}}
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{.Resource.Label}} - {{.SiteTitle}}</title>
  <link rel="stylesheet" href="{{.BasePath}}/static/admin.css">
  <script src="{{.BasePath}}/static/admin.js" defer></script>
</head>
<body>
  <header class="ga-header">
    <a class="ga-brand" href="{{.BasePath}}/">{{.SiteTitle}}</a>
    <nav>{{.App.Label}} / {{.Resource.Label}}</nav>
  </header>
  <main class="ga-shell">
    <div class="ga-title-row">
      <h1>{{.Resource.Label}}</h1>
      <a class="ga-button" href="{{.NewURL}}">Add {{.Resource.Label}}</a>
    </div>
    <form class="ga-toolbar" method="get">
      <input type="search" name="q" value="{{.Search}}" placeholder="Search">
      {{range .Filters}}
        <label>
          {{.Label}}
          <select name="{{.Name}}">
            <option value="">All</option>
            {{range .Choices}}
              <option value="{{.Value}}">{{.Label}}</option>
            {{end}}
          </select>
        </label>
      {{end}}
      <button type="submit">Apply</button>
    </form>
    <table class="ga-table">
      <thead>
        <tr>
          {{range .Columns}}<th>{{.LabelValue}}</th>{{end}}
        </tr>
      </thead>
      <tbody>
        {{range .Rows}}
          {{$row := .}}
          <tr>
            {{range $i, $cell := .Cells}}
              <td>{{if eq $i 0}}<a href="{{$.BasePath}}/{{$.App.Name}}/{{$.Resource.Name}}/{{$row.ID}}">{{formatValue $cell.Value}}</a>{{else}}{{formatValue $cell.Value}}{{end}}</td>
            {{end}}
          </tr>
        {{else}}
          <tr><td colspan="{{len .Columns}}">No rows found.</td></tr>
        {{end}}
      </tbody>
    </table>
    <p class="ga-muted">Showing page {{.Page.Page}} with {{len .Rows}} of {{.Page.Total}} rows.</p>
  </main>
</body>
</html>
{{end}}
