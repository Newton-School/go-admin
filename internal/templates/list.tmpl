{{define "list"}}
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{.Resource.Label}} - {{.SiteTitle}}</title>
  <link rel="stylesheet" href="{{.BasePath}}/static/admin.css">
  <script src="{{.BasePath}}/static/admin.js" defer></script>
</head>
<body>
  <header class="ga-header">
    <a class="ga-brand" href="{{.BasePath}}/">{{.SiteTitle}}</a>
    <nav>{{.App.Label}} / {{.Resource.Label}}</nav>
  </header>
  <main class="ga-shell">
    <div class="ga-title-row">
      <h1>{{.Resource.Label}}</h1>
      <a class="ga-button" href="{{.NewURL}}">Add {{.Resource.Label}}</a>
    </div>
    <form class="ga-toolbar" method="get">
      <input type="search" name="q" value="{{.Search}}" placeholder="Search">
      {{range .Filters}}
        <label>
          {{.Label}}
          <select name="{{.Name}}">
            <option value="">All</option>
            {{range .Choices}}
              <option value="{{.Value}}">{{.Label}}</option>
            {{end}}
          </select>
        </label>
      {{end}}
      <button type="submit">Apply</button>
    </form>
    {{if .Actions}}
    <form class="ga-actionbar" method="post" action="{{.ActionURL}}" data-ga-action-form>
      <input type="hidden" name="go_admin_csrf" value="{{.CSRFToken}}">
      <label>
        Action
        <select name="_action" data-ga-action-select>
          {{range .Actions}}
            <option value="{{$.BasePath}}/{{$.App.Name}}/{{$.Resource.Name}}/actions/{{.Name}}">{{.Label}}</option>
          {{end}}
        </select>
      </label>
      <button type="submit">Run</button>
    {{end}}
    <table class="ga-table">
      <thead>
        <tr>
          {{if .Actions}}<th>Select</th>{{end}}
          {{range .Columns}}<th>{{.LabelValue}}</th>{{end}}
        </tr>
      </thead>
      <tbody>
        {{range .Rows}}
          {{$row := .}}
          <tr>
            {{if $.Actions}}<td><input type="checkbox" name="ids" value="{{$row.ID}}"></td>{{end}}
            {{range $i, $cell := .Cells}}
              <td>{{if eq $i 0}}<a href="{{$.BasePath}}/{{$.App.Name}}/{{$.Resource.Name}}/{{$row.ID}}">{{formatValue $cell.Value}}</a>{{else}}{{formatValue $cell.Value}}{{end}}</td>
            {{end}}
          </tr>
        {{else}}
          <tr><td colspan="{{len .Columns}}">No rows found.</td></tr>
        {{end}}
      </tbody>
    </table>
    {{if .Actions}}</form>{{end}}
    <p class="ga-muted">Showing page {{.Page.Page}} with {{len .Rows}} of {{.Page.Total}} rows.</p>
  </main>
</body>
</html>
{{end}}
