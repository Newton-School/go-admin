{{define "index"}}
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{.PageTitle}} - {{.SiteTitle}}</title>
  <link rel="stylesheet" href="{{.BasePath}}/static/admin.css">
</head>
<body class="dashboard">
  <div id="container">
    <div id="header">
      <div id="branding">
        <h1 id="site-name"><a href="{{.BasePath}}/">{{.SiteTitle}}</a></h1>
      </div>
    </div>
    <div class="breadcrumbs"><a href="{{.BasePath}}/">Home</a></div>
    <div id="content" class="colMS">
      <h1>{{.PageTitle}}</h1>
      <div id="content-main">
        {{range .Apps}}
          {{$app := .}}
          <div class="module">
            <table>
              <caption><a href="{{$.BasePath}}/{{$app.Name}}/">{{$app.Label}}</a></caption>
              <tbody>
                {{range .Resources}}
                  <tr class="model-{{.Name}}">
                    <th scope="row"><a href="{{$.BasePath}}/{{$app.Name}}/{{.Name}}/">{{.Label}}</a></th>
                    <td><a class="addlink" href="{{$.BasePath}}/{{$app.Name}}/{{.Name}}/new">Add</a></td>
                    <td><a class="changelink" href="{{$.BasePath}}/{{$app.Name}}/{{.Name}}/">Change</a></td>
                  </tr>
                {{end}}
              </tbody>
            </table>
          </div>
        {{else}}
          <p>No resources registered.</p>
        {{end}}
      </div>
    </div>
  </div>
</body>
</html>
{{end}}
