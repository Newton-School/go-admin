{{define "delete"}}
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{.PageTitle}} - {{.SiteTitle}}</title>
  <link rel="stylesheet" href="{{.BasePath}}/static/admin.css">
</head>
<body class="app-{{.App.Name}} model-{{.Resource.Name}} delete-confirmation">
  <div id="container">
    <div id="header">
      <div id="branding">
        <h1 id="site-name"><a href="{{.BasePath}}/">{{.SiteTitle}}</a></h1>
      </div>
    </div>
    <div class="breadcrumbs">
      <a href="{{.BasePath}}/">Home</a> &rsaquo;
      <a href="{{.BasePath}}/{{.App.Name}}/">{{.App.Label}}</a> &rsaquo;
      <a href="{{.BackURL}}">{{.Resource.Label}}</a> &rsaquo;
      Delete
    </div>
    <div id="content" class="colM">
      <h1>{{.PageTitle}}</h1>
      <p>Are you sure you want to delete {{.Resource.Label}} #{{.ObjectID}}?</p>
      <form method="post" action="{{.ActionURL}}">
        <input type="hidden" name="go_admin_csrf" value="{{.CSRFToken}}">
        <div class="submit-row">
          <input type="submit" value="Yes, I am sure" class="deletelink">
          <a href="{{.BackURL}}" class="closelink">No, take me back</a>
        </div>
      </form>
    </div>
  </div>
</body>
</html>
{{end}}
